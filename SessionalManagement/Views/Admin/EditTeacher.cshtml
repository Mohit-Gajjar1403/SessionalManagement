@model Teacher

@{
    var subjects = ViewBag.Subjects as List<SubjectItem>;
}

<h2>Edit Teacher</h2>

<form asp-action="EditTeacher" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div>
        <label>Name</label>
        <input type="text" name="Name" value="@Model.Name" class="form-control" />
    </div>

    <div>
        <label>Email</label>
        <input type="email" name="Email" value="@Model.Email" class="form-control" />
    </div>

        <input type="hidden" name="Password" value="@Model.Password" class="form-control" />

    <div>
        <label>Subjects</label><br />
        @foreach (var subject in subjects)
        {
            <label>
                <input type="checkbox"
                       name="SelectedSubjects"
                       value="@subject.subject.Id"
                       @(subject.IsSelected ? "checked" : "") />
                @subject.subject.Name
            </label>
        
            <br />
        }
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>
